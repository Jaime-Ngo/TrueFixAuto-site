---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Veteran-owned auto repair in Colorado Springs. Honest work, fair prices, no runaround." } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | TrueFix Auto — Colorado Springs</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- NAV -->
  <nav>
    <a href="/" class="nav-logo">
      <div class="logo-wordmark">
        <span class="lw-true">TRUE</span><span class="lw-fix">FIX</span>
        <span class="lw-spacer"></span>
        <span class="lw-aut">AUT</span><span class="lw-tire" aria-label="O">
          <svg class="tire-svg" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="50" r="44" fill="none" stroke="currentColor" stroke-width="10"/>
            <circle cx="50" cy="50" r="27" fill="none" stroke="currentColor" stroke-width="4"/>
            <circle cx="50" cy="50" r="7" fill="currentColor"/>
            <line x1="50" y1="23" x2="50" y2="40" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
            <line x1="50" y1="60" x2="50" y2="77" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
            <line x1="23" y1="50" x2="40" y2="50" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
            <line x1="60" y1="50" x2="77" y2="50" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
            <line x1="29" y1="29" x2="41" y2="41" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
            <line x1="59" y1="59" x2="71" y2="71" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
            <line x1="71" y1="29" x2="59" y2="41" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
            <line x1="41" y1="59" x2="29" y2="71" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
          </svg>
        </span>
      </div>
      <div class="logo-sub">Where Integrity Drives</div>
    </a>

    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/reviews">Reviews</a></li>
      <li><a href="/contact">Contact</a></li>
      <li><a href="/contact" class="nav-cta">Book Appointment</a></li>
    </ul>

    <button class="hamburger" id="hamburger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- MOBILE DRAWER -->
  <div class="mobile-menu" id="mobile-menu">
    <a href="/">Home</a>
    <a href="/services">Services</a>
    <a href="/about">About</a>
    <a href="/reviews">Reviews</a>
    <a href="/contact">Contact</a>
    <a href="/contact" class="mobile-cta">Book Appointment</a>
  </div>

  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="footer-top">

      <div class="footer-brand">
        <div class="footer-logo">
          <span class="lw-true">TRUE</span><span class="lw-fix">FIX</span>
          <span class="lw-spacer"> </span>
          <span class="lw-aut">AUT</span><span class="lw-tire footer-tire" aria-label="O">
            <svg class="tire-svg" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
              <circle cx="50" cy="50" r="46" fill="none" stroke="currentColor" stroke-width="10"/>
              <circle cx="50" cy="50" r="28" fill="none" stroke="currentColor" stroke-width="5"/>
              <circle cx="50" cy="50" r="8" fill="currentColor"/>
              <line x1="50" y1="22" x2="50" y2="42" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
              <line x1="50" y1="58" x2="50" y2="78" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
              <line x1="22" y1="50" x2="42" y2="50" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
              <line x1="58" y1="50" x2="78" y2="50" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
              <line x1="30" y1="30" x2="44" y2="44" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
              <line x1="56" y1="56" x2="70" y2="70" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
              <line x1="70" y1="30" x2="56" y2="44" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
              <line x1="44" y1="56" x2="30" y2="70" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
            </svg>
          </span>
        </div>
        <div class="footer-tagline">Where Integrity Drives</div>
        <p>Veteran-owned auto repair in Colorado Springs. Honest work, fair prices, no runaround.</p>
        <div class="footer-socials">
          <a href="https://www.instagram.com/cowboysmechanicshop/" target="_blank" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="https://www.facebook.com/p/Cowboys-Mechanic-Shop-61580205101878/" target="_blank" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <h4>Pages</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/reviews">Reviews</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Contact</h4>
        <ul>
          <li><a href="tel:7208126036">720-812-6036</a></li>
          <li><a href="mailto:info@truefixauto.com">info@truefixauto.com</a></li>
          <li>
            <a href="https://maps.google.com/?q=3826+E+Pikes+Peak+Ave+Colorado+Springs+CO" target="_blank">
              3826 E Pikes Peak Ave<br>Colorado Springs, CO 80909
            </a>
          </li>
          <li class="hours">Mon – Sat: 9:00 AM – 6:00 PM</li>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <div class="footer-copy">© 2025 TrueFix Auto — Colorado Springs, CO. All rights reserved.</div>
      <div class="footer-legal">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </footer>

  <!-- FLOATING CALL BUTTON (mobile) -->
  <div class="fab-container" id="fab-container">
    <div class="fab-label">Call or Text</div>
    <div class="fab-menu" id="fab-menu">
      <a href="sms:7208126036" class="fab-option fab-text">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        Text Us
      </a>
      <a href="tel:7208126036" class="fab-option fab-call">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-2.85-8.62A2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        Call Now
      </a>
    </div>
    <button class="fab-main" id="fab-main" aria-label="Call or Text TrueFix Auto">
      <svg class="fab-icon-phone" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-2.85-8.62A2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
      <svg class="fab-icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <script>
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobile-menu');
    hamburger.addEventListener('click', () => {
      const open = mobileMenu.classList.toggle('open');
      hamburger.classList.toggle('active', open);
    });
    mobileMenu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        mobileMenu.classList.remove('open');
        hamburger.classList.remove('active');
      });
    });

    // FAB toggle
    const fabMain = document.getElementById('fab-main');
    const fabContainer = document.getElementById('fab-container');
    fabMain.addEventListener('click', () => {
      fabContainer.classList.toggle('open');
    });
    // Close FAB when clicking outside
    document.addEventListener('click', (e) => {
      if (!fabContainer.contains(e.target)) {
        fabContainer.classList.remove('open');
      }
    });
  </script>

</body>
</html>

<style is:global>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--black);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 60px;
    height: 68px;
    border-bottom: 2px solid var(--green);
  }

  .nav-logo {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    line-height: 1;
    flex-shrink: 0;
  }
  .logo-wordmark {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 24px;
    font-weight: 800;
    letter-spacing: -0.01em;
    white-space: nowrap;
    display: flex;
    align-items: center;
    line-height: 1;
  }
  .lw-true { color: var(--white); -webkit-text-stroke: 0px; }
  .lw-fix  { color: var(--green-light); }
  .lw-spacer { width: 0.35em; display: inline-block; }
  .lw-aut  { color: var(--white); -webkit-text-stroke: 0px; }
  .lw-tire {
    color: var(--green-light);
    display: inline-flex;
    align-items: center;
  }
  .tire-svg {
    width: 0.82em;
    height: 0.82em;
    vertical-align: middle;
  }
  .logo-sub {
    font-size: 9px;
    font-weight: 500;
    color: var(--green-light);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 2px;
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
    list-style: none;
  }
  .nav-links a {
    color: rgba(245,242,236,0.7);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .nav-links a:hover { color: var(--green-light); }
  .nav-cta {
    background: var(--green) !important;
    color: white !important;
    padding: 9px 20px;
    border-radius: 3px;
    font-weight: 600 !important;
    transition: background 0.2s !important;
  }
  .nav-cta:hover { background: var(--green-light) !important; }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 200;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
    transform-origin: center;
  }
  .hamburger.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.active span:nth-child(2) { opacity: 0; }
  .hamburger.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: var(--black);
    z-index: 99;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 80px 24px 40px;
    border-top: 2px solid var(--green);
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 36px;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(245,242,236,0.75);
    text-decoration: none;
    padding: 10px 0;
    width: 100%;
    text-align: center;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: color 0.2s;
  }
  .mobile-menu a:hover { color: var(--green-light); }
  .mobile-menu .mobile-cta {
    background: var(--green);
    color: white !important;
    border-radius: 3px;
    margin-top: 16px;
    border-bottom: none;
    padding: 16px 0;
  }
  .mobile-menu .mobile-cta:hover { background: var(--green-light); }

  /* FLOATING ACTION BUTTON */
  .fab-container {
    display: none;
    position: fixed;
    bottom: 24px;
    right: 20px;
    z-index: 300;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }

  .fab-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(245,242,236,0.5);
    margin-bottom: -4px;
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }
  .fab-container.open .fab-label { opacity: 1; }

  .fab-menu {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
    opacity: 0;
    transform: translateY(12px) scale(0.95);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .fab-container.open .fab-menu {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: all;
  }

  .fab-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border-radius: 50px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(0,0,0,0.35);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .fab-option:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.4); }

  .fab-call {
    background: var(--green);
    color: white;
  }
  .fab-text {
    background: var(--black);
    color: var(--green-light);
    border: 1px solid rgba(30,125,52,0.4);
  }

  .fab-main {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--green);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: 0 4px 20px rgba(30,125,52,0.5), 0 2px 8px rgba(0,0,0,0.3);
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .fab-main:hover {
    background: var(--green-light);
    transform: scale(1.08);
    box-shadow: 0 6px 24px rgba(30,125,52,0.6);
  }

  .fab-icon-phone, .fab-icon-close {
    position: absolute;
    transition: opacity 0.2s, transform 0.2s;
  }
  .fab-icon-close {
    opacity: 0;
    transform: rotate(-90deg);
  }
  .fab-container.open .fab-icon-phone {
    opacity: 0;
    transform: rotate(90deg);
  }
  .fab-container.open .fab-icon-close {
    opacity: 1;
    transform: rotate(0deg);
  }

  @media (max-width: 860px) {
    nav { padding: 0 24px; }
    .nav-links { display: none; }
    .hamburger { display: flex; }
    .fab-container { display: flex; }
  }

  @media (max-width: 600px) {
    nav { height: 56px; }
    .logo-sub { display: none; }
    .logo-wordmark { font-size: 20px; }
  }

  /* ── FOOTER ── */
  footer {
    background: #0a0c0a;
    border-top: 2px solid var(--green);
    padding: 56px 60px 28px;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    margin-bottom: 24px;
  }

  .footer-logo {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 26px;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    letter-spacing: -0.01em;
  }
  .footer-logo .lw-true,
  .footer-logo .lw-aut {
    color: #111;
    -webkit-text-stroke: 1.5px #f5f2ec;
    text-stroke: 1.5px #f5f2ec;
  }
  .footer-logo .lw-fix { color: var(--green-light); }
  .footer-tire .tire-svg { width: 0.82em; height: 0.82em; }

  .footer-tagline {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--green-light);
    margin-bottom: 14px;
  }

  .footer-brand p {
    font-size: 13px;
    color: rgba(245,242,236,0.4);
    line-height: 1.7;
    margin-bottom: 20px;
    max-width: 280px;
  }

  .footer-socials {
    display: flex;
    gap: 10px;
  }
  .footer-socials a {
    width: 38px; height: 38px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(245,242,236,0.5);
    text-decoration: none;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .footer-socials a:hover {
    background: var(--green);
    color: white;
    border-color: var(--green);
  }

  .footer-col h4 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white);
    margin-bottom: 16px;
  }
  .footer-col ul { list-style: none; }
  .footer-col ul li { margin-bottom: 10px; }
  .footer-col ul li a {
    font-size: 13px;
    color: rgba(245,242,236,0.45);
    text-decoration: none;
    line-height: 1.5;
    display: block;
    transition: color 0.2s;
  }
  .footer-col ul li a:hover { color: var(--green-light); }
  .footer-col .hours {
    font-size: 13px;
    color: rgba(245,242,236,0.3);
    margin-top: 4px;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .footer-copy {
    font-size: 12px;
    color: rgba(245,242,236,0.25);
  }
  .footer-legal {
    display: flex;
    gap: 20px;
  }
  .footer-legal a {
    font-size: 12px;
    color: rgba(245,242,236,0.25);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-legal a:hover { color: var(--green-light); }

  @media (max-width: 768px) {
    footer { padding: 48px 24px 24px; }
    .footer-top { grid-template-columns: 1fr; gap: 36px; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>