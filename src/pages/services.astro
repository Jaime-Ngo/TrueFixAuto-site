---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Services" description="Full-service auto repair and maintenance in Colorado Springs. Brakes, engine diagnostics, oil changes, AC service, and more.">

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div class="page-header-inner">
      <div class="section-label light">What We Do</div>
      <h1 class="section-title light">REPAIR &amp; MAINTENANCE SERVICES</h1>
      <p>Every job done right the first time in Colorado Springs. No upsells. No surprises on your bill.</p>
    </div>
  </div>

  <!-- WARRANTY BANNER -->
  <div class="warranty-banner">
    <div class="warranty-icon">🛡️</div>
    <div class="warranty-content">
      <div class="warranty-title">12 Months / 12,000 Miles Warranty</div>
      <div class="warranty-sub">On all parts and labor supplied by TrueFix Auto. We stand behind our work every time.</div>
    </div>
  </div>

  <!-- MILITARY DISCOUNT BANNER -->
  <div class="military-banner">
    <div class="military-icon">🎖️</div>
    <div class="military-content">
      <div class="military-title">Military &amp; First Responder Discount</div>
      <div class="military-sub">Active duty, veterans, and first responders receive a discount on all services. Just mention it when you call or come in.</div>
    </div>
    <a href="/contact" class="btn-primary military-cta">Request Quote</a>
  </div>

  <!-- SERVICES BODY -->
  <section class="services-section">

    <div class="category-block">
      <div class="category-heading">
        <span class="category-tag">Repair Services</span>
      </div>
      <div class="services-grid">

        <div class="service-card">
          <div class="service-name">Brake Services</div>
          <p class="service-desc">Pads, rotors, calipers, and full brake system inspections. We won't replace what doesn't need replacing.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Engine Diagnostics</div>
          <p class="service-desc">Check engine lights and performance issues diagnosed accurately. We explain what we find in plain English.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Engine Swaps</div>
          <p class="service-desc">Full engine swap services with precision and care. Ask us about your vehicle's specific requirements.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Suspension &amp; Steering</div>
          <p class="service-desc">Shocks, struts, steering components, and wheel alignment. Keeps your ride safe and comfortable on Colorado roads.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Cooling System Repairs</div>
          <p class="service-desc">Radiators, thermostats, water pumps, and hoses. Prevent overheating before it becomes an expensive problem.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Starter &amp; Alternator Replacement</div>
          <p class="service-desc">Electrical system diagnostics and component replacement so your vehicle starts and charges reliably every time.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Pre-Purchase Inspections</div>
          <p class="service-desc">Know what you're buying before you sign anything. A thorough, honest inspection report with no fluff.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Steering &amp; Wheel Alignment</div>
          <p class="service-desc">Proper alignment improves handling, reduces tire wear, and keeps you driving straight. Fast turnaround.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Fleet Services</div>
          <p class="service-desc">Scheduled maintenance and repairs for small business fleets. Priority scheduling and consistent service available.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

      </div>
    </div>

    <div class="category-block">
      <div class="category-heading">
        <span class="category-tag">Maintenance Services</span>
      </div>
      <div class="services-grid">

        <div class="service-card">
          <div class="service-name">Oil Changes</div>
          <p class="service-desc">Fast, thorough oil changes with the right oil for your vehicle. We check fluid levels and tire pressure while we're at it.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">AC Service &amp; Repair</div>
          <p class="service-desc">Recharge, leak detection, and full AC system repair. Don't endure a Colorado Springs summer without a working AC.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Tune-Ups &amp; Maintenance</div>
          <p class="service-desc">Spark plugs, filters, and full maintenance checks to keep your vehicle running at peak performance and efficiency.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Battery Service</div>
          <p class="service-desc">Testing, replacement, and terminal cleaning. We carry reliable stock and install while you wait. No appointment needed.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Belt Replacement</div>
          <p class="service-desc">Timing belts, serpentine belts, and drive belts inspected and replaced before they leave you stranded.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Fluid Top-Offs</div>
          <p class="service-desc">Brake fluid, coolant, power steering, transmission. We top off all fluids and flag anything that needs attention.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Seasonal Readiness Checks</div>
          <p class="service-desc">Get your vehicle ready for winter or summer with a full seasonal inspection. Colorado Springs weather is no joke.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Customer-Supplied Parts</div>
          <p class="service-desc">We'll install parts you bring in. No problem, no markup. Just our honest labor rate applied to your job.</p>
          <a href="/contact" class="service-link">Request Quote →</a>
        </div>

      </div>
    </div>

    <!-- COMING SOON -->
    <div class="category-block">
      <div class="category-heading">
        <span class="category-tag">Coming Soon</span>
      </div>
      <div class="services-grid coming-soon-grid">

        <div class="service-card coming-soon-card">

          <div class="service-name">TrueFix Mobile Service</div>
          <p class="service-desc">Can't make it to the shop? We're bringing TrueFix Auto to you. Mobile repair and maintenance service coming to Colorado Springs.</p>
          <a href="/contact" class="service-link">Get Notified →</a>
        </div>

      </div>
    </div>

  </section>

  <!-- CTA BANNER -->
  <div class="cta-banner">
    <div class="cta-inner">
      <h2>NOT SURE WHAT YOUR CAR NEEDS?</h2>
      <p>Call us or bring it in to our Colorado Springs shop. We'll diagnose it honestly and tell you exactly what's going on.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn-primary">Book an Appointment</a>
        <a href="tel:7208126036" class="cta-phone">720-812-6036</a>
      </div>
    </div>
  </div>

</Layout>

<style>
  .page-header {
    background: var(--black);
    border-bottom: 2px solid var(--green);
    padding: 72px 80px 60px;
  }
  .page-header-inner { max-width: 680px; }
  .page-header p {
    font-size: 16px;
    color: rgba(245,242,236,0.55);
    line-height: 1.7;
    margin-top: 16px;
  }

  /* WARRANTY BANNER */
  .warranty-banner {
    background: var(--green);
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 24px 80px;
  }
  .warranty-icon { font-size: 28px; flex-shrink: 0; }
  .warranty-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: white;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .warranty-sub {
    font-size: 13px;
    color: rgba(255,255,255,0.75);
    margin-top: 3px;
  }

  /* MILITARY BANNER */
  .military-banner {
    background: rgba(30,125,52,0.08);
    border-bottom: 1px solid rgba(30,125,52,0.2);
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 20px 80px;
  }
  .military-icon { font-size: 24px; flex-shrink: 0; }
  .military-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--green);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .military-sub {
    font-size: 13px;
    color: var(--gray);
    margin-top: 2px;
  }
  .military-content { flex: 1; }
  .military-cta { flex-shrink: 0; }

  /* SERVICES SECTION */
  .services-section {
    padding: 72px 80px;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .category-heading {
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--border);
  }

  .category-tag {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--black);
    position: relative;
    padding-left: 18px;
  }
  .category-tag::before {
    content: '';
    position: absolute;
    left: 0; top: 50%;
    transform: translateY(-50%);
    width: 6px; height: 6px;
    background: var(--green);
    border-radius: 50%;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    background: var(--border);
  }

  .service-card {
    background: var(--white);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    transition: background 0.2s;
  }
  .service-card:hover { background: var(--green-pale); }

  .service-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--black);
    margin-bottom: 10px;
    line-height: 1.15;
  }

  .service-desc {
    font-size: 13.5px;
    color: var(--gray);
    line-height: 1.65;
    flex: 1;
  }

  .service-link {
    display: inline-block;
    margin-top: 18px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--green);
    text-decoration: none;
    transition: color 0.2s;
  }
  .service-link:hover { color: var(--green-light); }

  /* COMING SOON */
  .coming-soon-grid {
    grid-template-columns: repeat(2, 1fr);
    background: none;
    gap: 0;
  }
  .coming-soon-card {
    background: var(--black);
    border: 2px dashed rgba(30,125,52,0.4);
    border-radius: 4px;
    position: relative;
  }
  .coming-soon-card:hover { background: #1a2a1a; }
  .coming-soon-card .service-name { color: var(--white); }
  .coming-soon-card .service-desc { color: rgba(245,242,236,0.45); }
  .coming-soon-card .service-link { color: var(--green-light); }

  .coming-soon-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(30,125,52,0.2);
    border: 1px solid rgba(30,125,52,0.4);
    color: var(--green-light);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 2px;
    margin-bottom: 14px;
    width: fit-content;
  }

  /* CTA BANNER */
  .cta-banner {
    background: var(--black);
    padding: 72px 80px;
    border-top: 2px solid var(--green);
  }
  .cta-inner { max-width: 640px; }
  .cta-inner h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 48px;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 14px;
    line-height: 1;
  }
  .cta-inner p {
    font-size: 15px;
    color: rgba(245,242,236,0.55);
    line-height: 1.7;
    margin-bottom: 32px;
  }
  .cta-actions {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
  }
  .cta-phone {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--green-light);
    text-decoration: none;
    letter-spacing: 0.04em;
  }
  .cta-phone:hover { text-decoration: underline; }

  @media (max-width: 768px) {
    .page-header { padding: 48px 24px 40px; }
    .warranty-banner { padding: 20px 24px; flex-wrap: wrap; }
    .military-banner { padding: 20px 24px; flex-wrap: wrap; }
    .military-cta { width: 100%; text-align: center; }
    .services-section { padding: 40px 24px; gap: 48px; }
    .services-grid { grid-template-columns: 1fr; }
    .coming-soon-grid { grid-template-columns: 1fr; }
    .cta-banner { padding: 48px 24px; }
    .cta-inner h2 { font-size: 34px; }
    .cta-actions { flex-direction: column; align-items: flex-start; gap: 16px; }
  }
</style>