---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Services" description="Full-service auto repair and maintenance in Colorado Springs. Brakes, engine diagnostics, oil changes, AC service, and more.">

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div class="page-header-inner">
      <div class="section-label light">What We Do</div>
      <h1 class="section-title light">REPAIR &amp; MAINTENANCE SERVICES</h1>
      <p>Every job done right the first time. No upsells. No surprises on your bill.</p>
    </div>
  </div>

  <!-- SERVICES BODY -->
  <section class="services-section">

    <div class="category-block">
      <div class="category-heading">
        <span class="category-tag">Repair Services</span>
      </div>
      <div class="services-grid">

        <div class="service-card">
          <div class="service-name">Brake Services</div>
          <p class="service-desc">Pads, rotors, calipers, and full brake system inspections. We won't replace what doesn't need replacing.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Engine Diagnostics</div>
          <p class="service-desc">Check engine lights and performance issues diagnosed accurately — we explain what we find in plain English.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Suspension &amp; Steering</div>
          <p class="service-desc">Shocks, struts, steering components, and wheel alignment. Keeps your ride safe and comfortable on Colorado roads.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Cooling System Repairs</div>
          <p class="service-desc">Radiators, thermostats, water pumps, and hoses. Prevent overheating before it becomes an expensive problem.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Starter &amp; Alternator Replacement</div>
          <p class="service-desc">Electrical system diagnostics and component replacement so your vehicle starts and charges reliably every time.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Pre-Purchase Inspections</div>
          <p class="service-desc">Know what you're buying before you sign anything. A thorough, honest inspection report with no fluff.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Steering &amp; Wheel Alignment</div>
          <p class="service-desc">Proper alignment improves handling, reduces tire wear, and keeps you driving straight. Fast turnaround.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Fleet Services</div>
          <p class="service-desc">Scheduled maintenance and repairs for small business fleets. Priority scheduling and consistent service available.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

      </div>
    </div>

    <div class="category-block">
      <div class="category-heading">
        <span class="category-tag">Maintenance Services</span>
      </div>
      <div class="services-grid">

        <div class="service-card">
          <div class="service-name">Oil Changes</div>
          <p class="service-desc">Fast, thorough oil changes with the right oil for your vehicle. We check fluid levels and tire pressure while we're at it.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

        <div class="service-card">
          <div class="service-name">AC Service &amp; Repair</div>
          <p class="service-desc">Recharge, leak detection, and full AC system repair. Don't endure a Colorado summer without a working AC.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Tune-Ups &amp; Maintenance</div>
          <p class="service-desc">Spark plugs, filters, and full maintenance checks to keep your vehicle running at peak performance and efficiency.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Battery Service</div>
          <p class="service-desc">Testing, replacement, and terminal cleaning. We carry reliable stock and install while you wait — no appointment needed.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Belt Replacement</div>
          <p class="service-desc">Timing belts, serpentine belts, and drive belts inspected and replaced before they leave you stranded.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Fluid Top-Offs</div>
          <p class="service-desc">Brake fluid, coolant, power steering, transmission — we top off all fluids and flag anything that needs attention.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Seasonal Readiness Checks</div>
          <p class="service-desc">Get your vehicle ready for winter or summer with a full seasonal inspection. Colorado weather is no joke.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Customer-Supplied Parts</div>
          <p class="service-desc">We'll install parts you bring in. No problem, no markup. Just our honest labor rate applied to your job.</p>
          <a href="/contact" class="service-link">Get Estimate →</a>
        </div>

      </div>
    </div>

    <div class="category-block">
      <div class="category-heading">
        <span class="category-tag">Additional Services</span>
      </div>
      <div class="services-grid">

        <div class="service-card">
          <div class="service-name">Vehicle Wrapping</div>
          <p class="service-desc">Full and partial vehicle wraps. Protect your paint or give your vehicle a new look. Ask about current availability.</p>
          <a href="/contact" class="service-link">Ask About This →</a>
        </div>

        <div class="service-card">
          <div class="service-name">Detailing</div>
          <p class="service-desc">Professional interior and exterior detailing. Leave with your vehicle looking as good as it runs.</p>
          <a href="/contact" class="service-link">Ask About This →</a>
        </div>

      </div>
    </div>

  </section>

  <!-- CTA BANNER -->
  <div class="cta-banner">
    <div class="cta-inner">
      <h2>NOT SURE WHAT YOUR CAR NEEDS?</h2>
      <p>Call us or bring it in. We'll diagnose it honestly and tell you exactly what's going on.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn-primary">Book an Appointment</a>
        <a href="tel:7208126036" class="cta-phone">720-812-6036</a>
      </div>
    </div>
  </div>

</Layout>

<style>
  /* PAGE HEADER */
  .page-header {
    background: var(--black);
    border-bottom: 2px solid var(--green);
    padding: 72px 80px 60px;
  }
  .page-header-inner { max-width: 680px; }
  .page-header p {
    font-size: 16px;
    color: rgba(245,242,236,0.55);
    line-height: 1.7;
    margin-top: 16px;
  }

  /* SERVICES SECTION */
  .services-section {
    padding: 72px 80px;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .category-block {}

  .category-heading {
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--border);
  }

  .category-tag {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--black);
    position: relative;
    padding-left: 18px;
  }
  .category-tag::before {
    content: '';
    position: absolute;
    left: 0; top: 50%;
    transform: translateY(-50%);
    width: 6px; height: 6px;
    background: var(--green);
    border-radius: 50%;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    background: var(--border);
  }

  .service-card {
    background: var(--white);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    transition: background 0.2s;
  }
  .service-card:hover { background: var(--green-pale); }

  .service-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--black);
    margin-bottom: 10px;
    line-height: 1.15;
  }

  .service-desc {
    font-size: 13.5px;
    color: var(--gray);
    line-height: 1.65;
    flex: 1;
  }

  .service-link {
    display: inline-block;
    margin-top: 18px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--green);
    text-decoration: none;
    transition: color 0.2s;
  }
  .service-link:hover { color: var(--green-light); }

  /* CTA BANNER */
  .cta-banner {
    background: var(--black);
    padding: 72px 80px;
    border-top: 2px solid var(--green);
  }
  .cta-inner { max-width: 640px; }
  .cta-inner h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 48px;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 14px;
    line-height: 1;
  }
  .cta-inner p {
    font-size: 15px;
    color: rgba(245,242,236,0.55);
    line-height: 1.7;
    margin-bottom: 32px;
  }
  .cta-actions {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
  }
  .cta-phone {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--green-light);
    text-decoration: none;
    letter-spacing: 0.04em;
  }
  .cta-phone:hover { text-decoration: underline; }

  @media (max-width: 768px) {
    .page-header { padding: 48px 24px 40px; }
    .services-section { padding: 40px 24px; gap: 48px; }
    .services-grid { grid-template-columns: 1fr; }
    .cta-banner { padding: 48px 24px; }
    .cta-inner h2 { font-size: 34px; }
    .cta-actions { flex-direction: column; align-items: flex-start; gap: 16px; }
  }
</style>