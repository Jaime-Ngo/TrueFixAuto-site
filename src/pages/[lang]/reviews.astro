---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'es' } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang as 'en' | 'es');
const currentPath = Astro.url.pathname;
---
<Layout t={t} currentPath={currentPath}>

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div class="page-header-inner">
      <div class="section-label light">{t.reviews.header.label}</div>
      <h1 class="section-title light">{t.reviews.header.title1}<br>{t.reviews.header.title2}</h1>
      <p>{t.reviews.header.sub}</p>
    </div>
    <div class="rating-badge">
      <div class="rating-stars">★★★★★</div>
      <div class="rating-num">5.0</div>
      <div class="rating-source">{t.reviews.header.ratingSource}</div>
    </div>
  </div>

  <!-- REVIEWS GRID -->
  <section class="reviews-section">
    <div class="reviews-grid">
      {t.reviews.items.map(review => (
        <div class="review-card">
          <div class="stars">★★★★★</div>
          <p class="review-text">{review.text}</p>
          <div class="review-footer">
            <div class="review-author">{review.author}</div>
            <div class="review-meta">{t.reviews.verified}</div>
          </div>
        </div>
      ))}
    </div>

    <div class="reviews-see-all">
      <a href="https://www.google.com/search?q=Cowboys+Mechanic+Shop+Colorado+Springs+Reviews&ludocid=18315268684440215550" target="_blank" class="btn-primary">{t.reviews.seeAll}</a>
    </div>
  </section>

</Layout>

<style>
  .page-header {
    background: var(--black);
    padding: 72px 80px 60px;
    border-bottom: 2px solid var(--green);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
  }
  .page-header-inner p { font-size: 16px; color: rgba(245,242,236,0.5); margin-top: 16px; }

  .rating-badge {
    text-align: center;
    background: rgba(30,125,52,0.15);
    border: 1px solid rgba(30,125,52,0.3);
    border-radius: 4px;
    padding: 24px 36px;
    flex-shrink: 0;
  }
  .rating-stars { font-size: 28px; color: var(--green-light); letter-spacing: 4px; margin-bottom: 8px; }
  .rating-num { font-family: 'Barlow Condensed', sans-serif; font-size: 52px; font-weight: 800; color: var(--white); line-height: 1; }
  .rating-source { font-size: 12px; color: rgba(245,242,236,0.4); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 6px; }

  .reviews-section { padding: 72px 80px; background: var(--green-pale); }
  .reviews-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .review-card { background: white; padding: 40px; border-radius: 4px; border-left: 3px solid var(--green); display: flex; flex-direction: column; }
  .stars { font-size: 20px; color: var(--green); letter-spacing: 3px; margin-bottom: 18px; }
  .review-text { font-size: 15px; color: var(--black); line-height: 1.75; font-style: italic; flex: 1; margin-bottom: 28px; }
  .review-footer {}
  .review-author { font-family: 'Barlow Condensed', sans-serif; font-size: 18px; font-weight: 700; color: var(--black); }
  .review-meta { font-size: 12px; color: var(--gray); margin-top: 3px; text-transform: uppercase; letter-spacing: 0.06em; }
  .reviews-see-all { display: flex; justify-content: center; padding-top: 48px; }

  @media (max-width: 768px) {
    .page-header { padding: 48px 24px 40px; flex-direction: column; align-items: flex-start; gap: 28px; }
    .rating-badge { width: 100%; padding: 20px; }
    .reviews-section { padding: 48px 24px; }
    .reviews-grid { grid-template-columns: 1fr; }
  }
</style>