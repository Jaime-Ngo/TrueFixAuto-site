---
import Layout from '../../layouts/Layout.astro';
import { getLang, useTranslations } from '../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'es' } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang as 'en' | 'es');
const currentPath = Astro.url.pathname;
---
<Layout t={t} currentPath={currentPath}>

  <section class="hero">
    <div class="hero-left">
      <div class="hero-line"></div>
      <div class="hero-badge">{t.home.hero.badge}</div>

      <div class="hero-wordmark">
        <span class="hw-true">TRUE</span><span class="hw-fix">FIX</span>
        <span class="hw-spacer"> </span>
        <span class="hw-aut">AUT</span><span class="hw-tire" aria-label="O">
          <svg class="hw-tire-svg" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <circle cx="50" cy="50" r="46" fill="none" stroke="currentColor" stroke-width="10"/>
            <circle cx="50" cy="50" r="28" fill="none" stroke="currentColor" stroke-width="5"/>
            <circle cx="50" cy="50" r="8" fill="currentColor"/>
            <line x1="50" y1="22" x2="50" y2="42" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
            <line x1="50" y1="58" x2="50" y2="78" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
            <line x1="22" y1="50" x2="42" y2="50" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
            <line x1="58" y1="50" x2="78" y2="50" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
            <line x1="30" y1="30" x2="44" y2="44" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
            <line x1="56" y1="56" x2="70" y2="70" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
            <line x1="70" y1="30" x2="56" y2="44" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
            <line x1="44" y1="56" x2="30" y2="70" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
          </svg>
        </span>
      </div>

      <h1 class="hero-title">
        {t.home.hero.headline1}<br>{t.home.hero.headline2} <span class="green">{t.home.hero.headline3}</span>
      </h1>
      <p class="hero-tagline">{t.home.hero.tagline}</p>
      <p class="hero-desc">{t.home.hero.desc}</p>
      <div class="hero-actions">
        <a href={`/${lang}/contact`} class="btn-primary">{t.home.hero.cta}</a>
        <a href="tel:7198773191" class="btn-outline">{t.home.hero.phone}</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="img-placeholder hero-img">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
        <div>HERO IMAGE</div>
        <div class="hint">{t.home.hero.imgAlt} · 900×600px</div>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    {t.home.trust.map((item, i) => (
      <>
        <div class="trust-item">{item}</div>
        {i < t.home.trust.length - 1 && <span class="dot"></span>}
      </>
    ))}
  </div>

  <section class="quick-section">
    <div class="quick-grid">
      <div class="quick-card dark">
        <div class="section-label light">{t.home.quick.services.label}</div>
        <h2 class="section-title light">{t.home.quick.services.title1}<br>{t.home.quick.services.title2}</h2>
        <p>{t.home.quick.services.desc}</p>
        <a href={`/${lang}/services`} class="btn-primary" style="margin-top:28px;">{t.home.quick.services.cta}</a>
      </div>
      <div class="quick-card light">
        <div class="section-label">{t.home.quick.about.label}</div>
        <h2 class="section-title">{t.home.quick.about.title1}<br>{t.home.quick.about.title2}</h2>
        <p style="color:var(--gray);">{t.home.quick.about.desc}</p>
        <a href={`/${lang}/about`} class="btn-primary" style="margin-top:28px;">{t.home.quick.about.cta}</a>
      </div>
      <div class="quick-card dark">
        <div class="section-label light">{t.home.quick.book.label}</div>
        <h2 class="section-title light">{t.home.quick.book.title1}<br>{t.home.quick.book.title2}</h2>
        <p style="color:rgba(245,242,236,0.55);margin-top:16px;">{t.home.quick.book.desc}</p>
        <a href={`/${lang}/contact`} class="btn-primary" style="margin-top:28px;">{t.home.quick.book.cta}</a>
      </div>
    </div>
  </section>

  <section class="reviews-preview">
    <div class="reviews-header">
      <div class="section-label centered">{t.home.reviews.label}</div>
      <h2 class="section-title" style="text-align:center;">{t.home.reviews.title1}<br>{t.home.reviews.title2}</h2>
    </div>
    <div class="reviews-row">
      {t.reviews.items.slice(0, 3).map(r => (
        <div class="review-card">
          <div class="stars">★★★★★</div>
          <p>{r.text}</p>
          <div class="reviewer">{r.author} · Google</div>
        </div>
      ))}
    </div>
    <div style="text-align:center;margin-top:36px;">
      <a href={`/${lang}/reviews`} class="btn-primary">{t.home.reviews.cta}</a>
    </div>
  </section>

</Layout>

<style>
  .hero {
    min-height: calc(100vh - 68px);
    background: var(--black);
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
  }
  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 60px 80px 80px;
    position: relative;
    z-index: 2;
  }
  .hero-line {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: linear-gradient(to bottom, transparent, var(--green), transparent);
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(30,125,52,0.15);
    border: 1px solid rgba(30,125,52,0.4);
    color: var(--green-light);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 2px;
    margin-bottom: 20px;
    width: fit-content;
  }
  .hero-badge::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--green-light);
    border-radius: 50%;
  }
  .hero-wordmark {
    display: flex;
    align-items: center;
    margin-bottom: 20px;
  }
  .hw-true, .hw-fix, .hw-aut {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(20px, 2.5vw, 30px);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .hw-true { color: #f5f2ec; }
  .hw-fix  { color: #27a045; }
  .hw-spacer { width: 0.35em; display: inline-block; }
  .hw-aut  { color: #f5f2ec; }
  .hw-tire { color: #27a045; display: inline-flex; align-items: center; }
  .hw-tire-svg {
    width: clamp(17px, 2.1vw, 26px);
    height: clamp(17px, 2.1vw, 26px);
    vertical-align: middle;
  }
  .hero-title {
    font-size: clamp(64px, 7vw, 96px);
    font-weight: 800;
    line-height: 0.92;
    color: var(--white);
    margin-bottom: 12px;
  }
  .hero-title .green { color: var(--green-light); }
  .hero-tagline {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 17px;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(245,242,236,0.4);
    margin-bottom: 36px;
  }
  .hero-desc {
    font-size: 16px;
    color: rgba(245,242,236,0.65);
    max-width: 400px;
    margin-bottom: 44px;
    line-height: 1.7;
  }
  .hero-actions { display: flex; gap: 24px; align-items: center; flex-wrap: wrap; }
  .hero-right { display: flex; align-items: center; justify-content: center; padding: 40px; }
  .hero-img { width: 100%; height: 100%; min-height: 420px; border-radius: 4px; }

  .trust-bar {
    background: var(--green);
    padding: 18px 80px;
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 16px;
    flex-wrap: wrap;
  }
  .trust-item {
    color: white;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .dot { width: 5px; height: 5px; background: rgba(255,255,255,0.35); border-radius: 50%; display: inline-block; }

  .quick-section { padding: 0; }
  .quick-grid { display: grid; grid-template-columns: repeat(3, 1fr); }
  .quick-card { padding: 64px 52px; }
  .quick-card p { font-size: 15px; line-height: 1.7; margin-top: 16px; }
  .quick-card.dark { background: var(--black); }
  .quick-card.dark p { color: rgba(245,242,236,0.55); }
  .quick-card.light { background: var(--white); border-top: 3px solid var(--border); }

  .reviews-preview { background: var(--green-pale); padding: 80px; }
  .reviews-header { margin-bottom: 48px; }
  .reviews-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .review-card { background: white; padding: 32px; border-radius: 4px; border-left: 3px solid var(--green); }
  .stars { color: var(--green); font-size: 18px; letter-spacing: 2px; margin-bottom: 14px; }
  .review-card p { font-size: 14px; color: var(--black); line-height: 1.7; font-style: italic; margin-bottom: 20px; }
  .reviewer { font-family: 'Barlow Condensed', sans-serif; font-size: 15px; font-weight: 700; color: var(--gray); }

  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-right { display: none; }
    .hero-left { padding: 56px 24px 64px; }
    .hero-title { font-size: clamp(52px, 14vw, 72px); }
    .trust-bar { padding: 16px 24px; gap: 12px; justify-content: center; }
    .dot { display: none; }
    .quick-grid { grid-template-columns: 1fr; }
    .quick-card { padding: 48px 24px; }
    .reviews-preview { padding: 56px 24px; }
    .reviews-row { grid-template-columns: 1fr; }
  }
</style>