---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About Us" description="TrueFix Auto is a veteran-owned auto repair shop in Colorado Springs. Honest work, fair prices, and straight-talk on every job.">

  <!-- PAGE HEADER -->
  <div class="page-header">
    <div class="section-label light">Our Story</div>
    <h1 class="section-title light">VETERAN OWNED.<br>COMMUNITY DRIVEN.</h1>
  </div>

  <!-- MAIN ABOUT SPLIT -->
  <section class="about-main">
    <div class="about-img-col">
      <!-- OWNER/TEAM PHOTO — Replace with real image -->
      <div class="img-placeholder about-img">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
        <div>OWNER / TEAM PHOTO</div>
        <div class="hint">600×750px portrait recommended</div>
      </div>
      <div class="img-accent"></div>
    </div>

    <div class="about-content">
      <div class="section-label">Who We Are</div>
      <h2 class="section-title">MORE THAN JUST<br>A MECHANIC SHOP.</h2>
      <p>
        TrueFix Auto was built on a simple principle: treat every customer the way you'd want to be treated.
        As a veteran-owned shop, we bring military-grade discipline and precision to every repair —
        whether it's a quick oil change or a full engine overhaul.
      </p>
      <p>
        We never upsell. We never talk over your head. We tell you exactly what your vehicle needs,
        what it doesn't, and what it'll cost — before we touch anything. That's the TrueFix standard.
      </p>
      <p>
        Colorado Springs is our community. Whether you're a local, a first-time customer, or just passing
        through — you'll get the same honest, quality service every single time.
      </p>
      <a href="/contact" class="btn-primary">Get a Free Estimate</a>
    </div>
  </section>

  <!-- STATS ROW -->
  <div class="stats-row">
    <div class="stat">
      <div class="stat-num">5★</div>
      <div class="stat-label">Google Rating</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <div class="stat-num">Mon–Sat</div>
      <div class="stat-label">Open 9AM – 6PM</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <div class="stat-num">Veteran</div>
      <div class="stat-label">Owned &amp; Operated</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <div class="stat-num">10% Off</div>
      <div class="stat-label">Military &amp; First Responders</div>
    </div>
  </div>

  <!-- VALUES -->
  <section class="values-section">
    <div class="values-header">
      <div class="section-label centered">Why Choose Us</div>
      <h2 class="section-title" style="text-align:center;">THE TRUEFIX STANDARD</h2>
    </div>

    <div class="values-grid">
      <div class="value-card">
        <div class="value-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3>No Upsells. Ever.</h3>
        <p>We recommend only what your vehicle actually needs. If it doesn't need it, we won't sell it to you — period.</p>
      </div>

      <div class="value-card">
        <div class="value-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <h3>Clear Communication</h3>
        <p>No jargon, no runaround. We explain what's wrong, what we're going to do about it, and what it costs — upfront.</p>
      </div>

      <div class="value-card">
        <div class="value-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3>Fast Turnaround</h3>
        <p>We respect your time. Same-day service is available for most jobs, and we don't drag our feet on repairs.</p>
      </div>

      <div class="value-card">
        <div class="value-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Military Precision</h3>
        <p>Veteran ownership means attention to detail isn't optional — it's how we operate. Every vehicle gets our full focus.</p>
      </div>
    </div>
  </section>

  <!-- SHOP PHOTOS ROW -->
  <section class="photos-section">
    <div class="section-label">The Shop</div>
    <h2 class="section-title">COME SEE US</h2>
    <div class="photos-grid">
      <!-- SHOP PHOTOS — Replace placeholders with real shop images -->
      <div class="img-placeholder shop-photo">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
        <div>SHOP PHOTO 1</div>
        <div class="hint">Bay / exterior · 600×400px</div>
      </div>
      <div class="img-placeholder shop-photo">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
        <div>SHOP PHOTO 2</div>
        <div class="hint">Team at work · 600×400px</div>
      </div>
      <div class="img-placeholder shop-photo">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
        <div>SHOP PHOTO 3</div>
        <div class="hint">Interior / signage · 600×400px</div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-header {
    background: var(--black);
    padding: 72px 80px 60px;
    border-bottom: 2px solid var(--green);
  }

  /* ABOUT MAIN */
  .about-main {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 80px;
    align-items: center;
    padding: 80px;
    background: var(--white);
  }

  .about-img-col { position: relative; padding-bottom: 20px; padding-right: 20px; }

  .about-img {
    width: 100%;
    aspect-ratio: 4/5;
    position: relative;
    z-index: 1;
  }

  .img-accent {
    position: absolute;
    bottom: 0; right: 0;
    width: 100px; height: 100px;
    background: var(--green);
    border-radius: 3px;
    z-index: 0;
  }

  .about-content p {
    font-size: 15.5px;
    color: var(--gray);
    line-height: 1.8;
    margin-bottom: 20px;
  }
  .about-content p:last-of-type { margin-bottom: 36px; }

  /* STATS */
  .stats-row {
    background: var(--black);
    display: flex;
    align-items: center;
    justify-content: space-around;
    padding: 56px 80px;
    gap: 24px;
  }

  .stat { text-align: center; }
  .stat-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 40px;
    font-weight: 800;
    color: var(--green-light);
    line-height: 1;
  }
  .stat-label {
    font-size: 13px;
    color: rgba(245,242,236,0.45);
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
  }
  .stat-divider {
    width: 1px;
    height: 60px;
    background: rgba(255,255,255,0.08);
  }

  /* VALUES */
  .values-section {
    padding: 80px;
    background: var(--green-pale);
  }
  .values-header { margin-bottom: 52px; }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .value-card {
    background: white;
    padding: 36px 28px;
    border-radius: 4px;
    border-top: 3px solid var(--green);
  }

  .value-icon {
    width: 52px; height: 52px;
    background: var(--green-pale);
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--green);
    margin-bottom: 20px;
  }

  .value-card h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--black);
    margin-bottom: 10px;
  }

  .value-card p {
    font-size: 14px;
    color: var(--gray);
    line-height: 1.65;
  }

  /* PHOTOS */
  .photos-section { padding: 80px; }
  .photos-section h2 { margin-bottom: 36px; }

  .photos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .shop-photo {
    width: 100%;
    aspect-ratio: 3/2;
  }

  @media (max-width: 768px) {
    .page-header { padding: 48px 24px 40px; }
    .about-main { grid-template-columns: 1fr; padding: 48px 24px; gap: 0; }
    .about-img-col { display: none; }
    .stats-row { flex-direction: column; padding: 48px 24px; gap: 32px; }
    .stat-divider { width: 60px; height: 1px; }
    .values-section { padding: 48px 24px; }
    .values-grid { grid-template-columns: 1fr; gap: 16px; }
    .photos-section { padding: 48px 24px; }
    .photos-grid { grid-template-columns: 1fr; }
  }
</style>